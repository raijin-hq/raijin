        "--source-maps",
        "-s"
      ],
      "description": "Generate source maps",
      "takes_arg": true,
      "arg_name": "SOURCE_MAP",
      "arg_template": {
        "custom": [
          "true",
          "false",
          "inline",
          "both"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--source-map-target"
      ],
      "description": "Define the file for the source map",
      "takes_arg": true,
      "arg_name": "FILE",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--source-file-name"
      ],
      "description": "Set sources[0] on returned source map",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--source-root"
      ],
      "description": "The root from which all sources are relative",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--out-file",
        "-o"
      ],
      "description": "Compile all input files into a single file",
      "takes_arg": true,
      "arg_name": "OUTPUT_FILE",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--out-dir",
        "-d"
      ],
      "description": "Compile an input directory of modules into an output directory",
      "takes_arg": true,
      "arg_name": "OUTPUT_DIR",
      "arg_template": "folders",
      "is_repeatable": false
    },
    {
      "names": [
        "--copy-files",
        "-D"
      ],
