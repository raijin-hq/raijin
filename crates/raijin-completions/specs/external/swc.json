      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--config",
        "-C"
      ],
      "description": "Override a config from .swcrc file",
      "takes_arg": true,
      "arg_name": "CONFIG_FILE",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--sync"
      ],
      "description": "Invoke swc synchronously. Useful for debugging",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--log-watch-compilation"
      ],
      "description": "Log a message when a watched file is successfully compiled",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--extensions"
      ],
      "description": "Log a message when a watched file is successfully compiled",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    }
  ],
  "args": []
