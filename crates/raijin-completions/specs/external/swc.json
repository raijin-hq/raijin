{
  "name": "swc",
  "aliases": [],
  "description": "SWC is a super-fast compiler written in rust; producing widely-supported javascript from modern standards and typescript",
  "subcommands": [],
  "options": [
    {
      "names": [
        "--filename",
        "-f"
      ],
      "description": "Filename to use when reading from stdin. This will be used in source maps and errors",
      "takes_arg": true,
      "arg_name": "FILE",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--config-file"
      ],
      "description": "Path to a .swcrc file to use",
      "takes_arg": true,
      "arg_name": "CONFIG_FILE",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--env-name"
      ],
      "description": "The name of the 'env' to use when loading configs and plugins. Defaults to the value of SWC_ENV, or else NODE_ENV, or else development",
      "takes_arg": true,
      "arg_name": "ENV_NAME",
      "arg_template": {
        "custom": [
          "production",
          "development",
          "test"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--no-swcrc"
      ],
      "description": "Whether or not to look up .swcrc files",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--ignore"
      ],
      "description": "List of glob paths to not compile",
      "takes_arg": true,
      "arg_name": "PATH",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--only"
      ],
      "description": "List of glob paths to only compile",
      "takes_arg": true,
      "arg_name": "PATH",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--watch",
        "-w"
      ],
      "description": "Watch for changes and recompile",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--quiet",
        "-q"
      ],
      "description": "Suppress compilation output",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
