          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--timeout"
          ],
          "description": "Specifies num seconds that a multicast client should wait when no payload data has been received over a multicast stream before exiting",
          "takes_arg": true,
          "arg_name": "num",
          "arg_template": {
            "custom": [
              "0"
            ]
          },
          "is_repeatable": false
        },
        {
          "names": [
            "--puppetstrings"
