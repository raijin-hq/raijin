{
  "name": "ansible-doc",
  "aliases": [],
  "description": "Displays information on modules installed in Ansible libraries",
  "subcommands": [],
  "options": [
    {
      "names": [
        "--metadata-dump"
      ],
      "description": "For internal testing only Dump json metadata for all plugins",
      "takes_arg": true,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--playbook-dir"
      ],
