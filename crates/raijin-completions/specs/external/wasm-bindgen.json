{
  "name": "wasm-bindgen",
  "aliases": [],
  "description": "Generate bindings between WebAssembly and JavaScript",
  "subcommands": [],
  "options": [
    {
      "names": [
        "--help",
        "-h"
      ],
      "description": "Show help for wasm-bindgen",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--version",
        "-v"
      ],
      "description": "Show version for wasm-bindgen",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--out-dir"
      ],
      "description": "Output directory",
      "takes_arg": true,
      "arg_name": "directory",
      "arg_template": "folders",
      "is_repeatable": false
    },
    {
      "names": [
        "--out-name"
      ],
      "description": "Set a custom output filename (Without extension. Defaults to crate name)",
      "takes_arg": true,
      "arg_name": "filename",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--target"
      ],
      "description": "What type of output to generate",
      "takes_arg": true,
      "arg_name": "target",
      "arg_template": {
        "custom": [
          "web",
          "bundler",
          "nodejs",
          "no-modules",
          "deno"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--no-modules-global"
      ],
      "description": "Name of global to assign generated bindings to",
      "takes_arg": true,
      "arg_name": "name",
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--browser"
      ],
      "description": "Hint that JS should only be compatible with a browser",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--typescript"
      ],
      "description": "Output a TypeScript definition file (on by default)",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--no-typescript"
      ],
      "description": "Don't emit a *.d.ts file",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--omit-imports"
      ],
      "description": "Don't emit imports in generated JavaScript",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--debug"
      ],
      "description": "Include otherwise-extraneous debug checks in output",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--no-demangle"
      ],
      "description": "Don't demangle Rust symbol names",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--keep-debug"
      ],
      "description": "Keep debug sections in wasm files",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--remove-name-section"
      ],
      "description": "Remove the debugging `name` section of the file",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--remove-producers-section"
      ],
      "description": "Remove the telemetry `producers` section",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--omit-default-module-path"
      ],
      "description": "Don't add WebAssembly fallback imports in generated JavaScript",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--encode-into"
      ],
      "description": "Whether or not to use TextEncoder#encodeInto()",
      "takes_arg": true,
      "arg_name": "option",
      "arg_template": {
        "custom": [
          "test",
          "always",
          "never"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--nodejs"
      ],
      "description": "Deprecated, use `--target nodejs`",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--web"
      ],
      "description": "Deprecated, use `--target web`",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--no-modules"
      ],
      "description": "Deprecated, use `--target no-modules`",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--weak-refs"
      ],
      "description": "Enable usage of the JS weak references proposal",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--reference-types"
      ],
      "description": "Enable usage of WebAssembly reference types",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    }
  ],
  "args": [
    {
      "name": "input",
      "description": "File name to output the compiled binary bindings",
      "template": null,
      "is_optional": false,
      "is_variadic": false
    }
  ]
}
