{
  "name": "ruff",
  "aliases": [],
  "description": "Ruff: An extremely fast Python linter",
  "subcommands": [
    {
      "name": "check",
      "aliases": [],
      "description": "Run Ruff on the given files or directories",
      "subcommands": [],
      "options": [
        {
          "names": [
            "--fix"
          ],
          "description": "Apply fixes to resolve lint violations",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--unsafe-fixes"
          ],
          "description": "Include fixes that may not retain the original intent of the code",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--show-fixes"
          ],
          "description": "Show an enumeration of all fixed lint violations",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--diff"
          ],
          "description": "Avoid writing any fixed files back; instead, output a diff for each changed file to stdout, and exit 0 if there are no diffs. Implies `--fix-only`",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "-w",
            "--watch"
          ],
          "description": "Run in watch mode by re-running whenever files change",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--fix-only"
          ],
          "description": "Apply fixes to resolve lint violations, but don't report on, or exit non-zero for, leftover violations. Implies `--fix`",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--ignore-noqa"
          ],
          "description": "Ignore any `# noqa` comments",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--output-format"
          ],
          "description": "Output serialization format for violations. The default serialization format is 'full'",
          "takes_arg": true,
          "arg_name": "output_format",
          "arg_template": {
            "custom": [
              "concise",
              "full",
              "json",
              "json-lines",
              "junit",
              "grouped",
              "github",
              "gitlab",
              "pylint",
              "rdjson",
              "azure",
              "sarif"
            ]
          },
          "is_repeatable": false
        },
        {
          "names": [
            "-o",
            "--output-file"
          ],
          "description": "Specify file to write the linter output to (default: stdout)",
          "takes_arg": true,
          "arg_name": "output_file",
          "arg_template": "filepaths",
          "is_repeatable": false
        },
        {
          "names": [
            "--target-version"
          ],
          "description": "The minimum Python version that should be supported",
          "takes_arg": true,
          "arg_name": "target_version",
          "arg_template": {
            "custom": [
              "py37",
              "py38",
              "py39",
              "py310",
              "py311",
              "py312",
              "py313"
            ]
          },
          "is_repeatable": false
        },
        {
          "names": [
            "--preview"
          ],
          "description": "Enable preview mode; checks will include unstable rules and fixes",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--extension"
          ],
          "description": "List of mappings from file extension to language (one of `python`, `ipynb`, `pyi`). For example, to treat `.ipy` files as IPython notebooks, use `--extension ipy:ipynb`",
          "takes_arg": true,
          "arg_name": "extension",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--statistics"
          ],
          "description": "Show counts for every rule with at least one violation",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--add-noqa"
          ],
          "description": "Enable automatic additions of `noqa` directives to failing lines",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--show-files"
          ],
          "description": "See the files Ruff will be run against with the current settings",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--show-settings"
          ],
          "description": "See the settings Ruff will use to lint a given Python file",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "-h",
            "--help"
          ],
          "description": "Print help",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--select"
          ],
          "description": "Comma-separated list of rule codes to enable (or ALL, to enable all rules)",
          "takes_arg": true,
          "arg_name": "select",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--ignore"
          ],
          "description": "Comma-separated list of rule codes to disable",
          "takes_arg": true,
          "arg_name": "ignore",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--extend-select"
          ],
          "description": "Like --select, but adds additional rule codes on top of the selected ones",
          "takes_arg": true,
          "arg_name": "extend_select",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--per-file-ignores"
          ],
          "description": "List of mappings from file pattern to code to exclude",
          "takes_arg": true,
          "arg_name": "per_file_ignores",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--extend-per-file-ignores"
          ],
          "description": "Like `--per-file-ignores`, but adds additional ignores on top of those already specified",
          "takes_arg": true,
          "arg_name": "extend_per_file_ignores",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--fixable"
          ],
          "description": "List of rule codes to treat as eligible for fix. Only applicable when fix itself is enabled (e.g., via `--fix`)",
          "takes_arg": true,
          "arg_name": "fixable",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--unfixable"
          ],
          "description": "List of rule codes to treat as ineligible for fix. Only applicable when fix itself is enabled (e.g., via `--fix`)",
          "takes_arg": true,
          "arg_name": "unfixable",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--extend-fixable"
          ],
          "description": "Like --fixable, but adds additional rule codes on top of those already specified",
          "takes_arg": true,
          "arg_name": "extend_fixable",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--exclude"
          ],
          "description": "List of paths, used to omit files and/or directories from analysis",
          "takes_arg": true,
          "arg_name": "exclude",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--extend-exclude"
          ],
          "description": "Like --exclude, but adds additional files and directories on top of those already excluded",
          "takes_arg": true,
          "arg_name": "extend_exclude",
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--respect-gitignore"
          ],
          "description": "Respect file exclusions via `.gitignore` and other standard ignore files",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--force-exclude"
          ],
          "description": "Enforce exclusions, even for paths passed to Ruff directly on the command-line",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "-n",
            "--no-cache"
          ],
          "description": "Disable cache reads",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--cache-dir"
          ],
          "description": "Path to the cache directory",
          "takes_arg": true,
          "arg_name": "cache_dir",
          "arg_template": "filepaths",
          "is_repeatable": false
        },
        {
          "names": [
            "--stdin-filename"
          ],
          "description": "The name of the file when passing it through stdin",
          "takes_arg": true,
          "arg_name": "stdin_filename",
          "arg_template": "filepaths",
          "is_repeatable": false
        },
        {
          "names": [
            "-e",
            "--exit-zero"
          ],
          "description": "Exit with status code \"0\", even upon detecting lint violations",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        },
        {
          "names": [
            "--exit-non-zero-on-fix"
          ],
          "description": "Exit with a non-zero status code if any files were modified via fix, even if no lint violations remain",
          "takes_arg": false,
          "arg_name": null,
          "arg_template": null,
          "is_repeatable": false
        }
      ],
      "args": [
        {
          "name": "Path",
          "description": "The path to use for the project/script",
          "template": "filepaths",
          "is_optional": false,
          "is_variadic": true
        }
      ]
    },
