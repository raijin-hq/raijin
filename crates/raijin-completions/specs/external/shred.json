{
  "name": "shred",
  "aliases": [],
  "description": "Overwrite a file to hide its contents, and optionally delete it",
  "subcommands": [],
  "options": [
    {
      "names": [
        "--force",
        "-f"
      ],
      "description": "Change permissions to allow writing if necessary",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--iterations",
        "-n"
      ],
      "description": "Overwrite N times instead of the default (3)",
      "takes_arg": true,
      "arg_name": "N",
      "arg_template": {
        "custom": [
          "3",
          "5",
          "7"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--random-source"
      ],
      "description": "Get random bytes from FILE",
      "takes_arg": true,
      "arg_name": "FILE",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--size",
        "-s"
      ],
      "description": "Shred this many bytes (suffixes like K, M, G accepted)",
      "takes_arg": true,
      "arg_name": "N",
      "arg_template": {
        "custom": [
          "1K",
          "1M",
          "1G"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--remove"
      ],
      "description": "Like -u but give control on HOW to delete",
      "takes_arg": true,
      "arg_name": "HOW",
      "arg_template": {
        "custom": [
          "unlink",
          "wipe",
          "wipesync"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--verbose",
        "-v"
      ],
      "description": "Show progress",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--exact",
        "-x"
      ],
      "description": "Do not round file sizes up to the next full block; this is the default for non-regular files",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--zero",
        "-z"
      ],
      "description": "Add a final overwrite with zeros to hide shredding",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--help"
      ],
      "description": "Display this help and exit",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--version"
      ],
      "description": "Output version information and exit",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    }
  ],
  "args": [
    {
      "name": "FILE",
      "description": "File(s) to shred",
      "template": "filepaths",
      "is_optional": false,
      "is_variadic": true
    }
  ]
}
