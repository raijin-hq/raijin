{
  "name": "ansible-lint",
  "aliases": [],
  "description": "Ansible static code analysis",
  "subcommands": [],
  "options": [
    {
      "names": [
        "--help",
        "-h"
      ],
      "description": "Show help for ansible-lint",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--list-rules",
        "-L"
      ],
      "description": "List all the rules",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--list-tags",
        "-T"
      ],
      "description": "List all the tags and the rules they cover",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--format",
        "-f"
      ],
      "description": "Stdout formatting",
      "takes_arg": true,
      "arg_name": "-f",
      "arg_template": {
        "custom": [
          "rich",
          "plain",
          "md",
          "json",
          "codeclimate",
          "quiet",
          "pep8",
          "sarif"
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "-q"
      ],
      "description": "Quieter, reduce verbosity, can be specified twice",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": true
    },
    {
      "names": [
        "-p"
      ],
      "description": "Parseable output, same as '-f pep8'",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--progressive"
      ],
      "description": "Return success if it detects a reduction in number of violations compared with previous git commit. This feature works only in git repositories",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--project-dir"
      ],
      "description": "Location of project/repository, autodetected based on location of configuration file",
      "takes_arg": true,
      "arg_name": "PROJECT_DIR",
      "arg_template": "folders",
      "is_repeatable": false
    },
    {
      "names": [
        "--rules-dir",
        "-r"
      ],
      "description": "Specify custom rule directories",
      "takes_arg": true,
      "arg_name": "RULESDIR",
      "arg_template": "folders",
      "is_repeatable": false
    },
    {
      "names": [
        "-R"
      ],
      "description": "Keep using embedded rules when using '-r'",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--write"
      ],
      "description": "Allow ansible-lint to reformat YAML files and run rule transforms",
      "takes_arg": true,
      "arg_name": "WRITE_LIST",
      "arg_template": {
        "custom": [
          "all",
          "none",
          "rule1,rule2,..."
        ]
      },
      "is_repeatable": false
    },
    {
      "names": [
        "--show-relpath"
      ],
      "description": "Display path relative to CWD",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--tags",
        "-t"
      ],
      "description": "Only check rules whose id/tags match these values",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "-v"
      ],
      "description": "Increase verbosity level (-vv for more)",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": true
    },
    {
      "names": [
        "--skip-list",
        "-x"
      ],
      "description": "Only check rules whose id/tags do not match these values",
      "takes_arg": true,
      "arg_name": "SKIP_LIST",
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--warn-list",
        "-w"
      ],
      "description": "Only warn about these rules, unless overridden in config file defaults to 'experimental'",
      "takes_arg": true,
      "arg_name": "WARN_LIST",
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--enable-list"
      ],
      "description": "Activate optional rules by their tag name",
      "takes_arg": true,
      "arg_name": "ENABLE_LIST",
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--nocolor"
      ],
      "description": "Disable colored output, same as NO_COLOR=1",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--force-color"
      ],
      "description": "Force colored output, same as FORCE_COLOR=1",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--exclude-paths"
      ],
      "description": "Path to directories or files to skip. This option is repeatable",
      "takes_arg": true,
      "arg_name": "EXCLUDE_PATHS",
      "arg_template": "folders",
      "is_repeatable": false
    },
    {
      "names": [
        "--config-file"
      ],
      "description": "Specify configuration file to use. By default it will look for '.ansible-lint' or '.config/ansible-lint.yml'",
      "takes_arg": true,
      "arg_name": "CONFIG_FILE",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--offline"
      ],
      "description": "Disable installation of requirements.yml",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "--version"
      ],
      "description": "Show version of ansible-lint",
      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    }
  ],
  "args": [
    {
      "name": "lintables",
      "description": "Files to lint",
      "template": "filepaths",
      "is_optional": true,
      "is_variadic": true
    }
  ]
}
