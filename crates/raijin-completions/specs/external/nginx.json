      "takes_arg": false,
      "arg_name": null,
      "arg_template": null,
      "is_repeatable": false
    },
    {
      "names": [
        "-t"
      ],
      "description": "Do not run, just test the configuration file.  nginx checks the configuration file syntax and then tries to open files referenced in the configuration file",
      "takes_arg": false,
