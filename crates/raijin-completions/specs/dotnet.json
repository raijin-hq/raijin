      "description": "Path containing probing policy and assemblies to probe",
      "takes_arg": true,
      "arg_name": "path",
      "arg_template": "folders",
      "is_repeatable": false
    },
    {
      "names": [
        "--additional-deps"
      ],
      "description": "Path to an additional .deps.json file. A deps.json file contains a list of dependencies, compilation dependencies, and version information used to address assembly conflicts. For more information, see Runtime Configuration Files on GitHub",
      "takes_arg": true,
      "arg_name": "deps",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "-depsfile"
      ],
      "description": "Path to the deps.json file. A deps.json file is a configuration file that contains information about dependencies necessary to run the application. This file is generated by the .NET SDK",
      "takes_arg": true,
      "arg_name": "deps",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--runtimeconfig"
      ],
      "description": "Path to a runtimeconfig.json file. A runtimeconfig.json file is a configuration file that contains run-time settings",
      "takes_arg": true,
      "arg_name": "path",
      "arg_template": "filepaths",
      "is_repeatable": false
    },
    {
      "names": [
        "--roll-forward"
      ],
      "description": "Controls how roll forward is applied to the app. The SETTING can be one of the following values. If not specified, Minor is the default",
